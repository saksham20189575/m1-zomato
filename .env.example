# Copy to `.env` (never commit `.env`). Phase 4+ will read these.

# Phase 4 — Groq (OpenAI-compatible chat completions).
# https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override default model (see Groq docs for current model ids).
# GROQ_MODEL=llama-3.3-70b-versatile

# Legacy / other providers (not used by the Groq Phase 4 CLI path).
# OPENAI_API_KEY=
# LLM_API_KEY=

# Optional: higher Hugging Face Hub rate limits for dataset downloads.
# HF_TOKEN=
